[Unit]
Description=LocalGitLabGateway Public Gateway Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/local-gitlab-gateway
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/local-gitlab-gateway/.venv/bin/local-gitlab-gateway-public
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
